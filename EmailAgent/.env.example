OLLAMA_BASE_URL=http://localhost:11434
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_ENABLED=true
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_ENABLED=false
GROQ_API_KEY=
