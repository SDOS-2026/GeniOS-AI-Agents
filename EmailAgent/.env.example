OLLAMA_BASE_URL=http://localhost:11434
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_ENABLED=true
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=your_anon_public_key_here
